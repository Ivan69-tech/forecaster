          "rawSql": "SELECT\n    timestamp AT TIME ZONE 'Europe/Paris' AS \"Heure (Paris)\",\n    ROUND(prix_eur_mwh::numeric, 2) AS \"Prix (€/MWh)\",\n    TO_CHAR(date_generation AT TIME ZONE 'Europe/Paris', 'DD/MM HH24:MI') AS \"Récupéré le\"\nFROM (\n    SELECT DISTINCT ON (timestamp) timestamp, prix_eur_mwh, date_generation\n    FROM forecasts_prix_spot\n    WHERE timestamp >= NOW()\n      AND timestamp < NOW() + INTERVAL '24 hours'\n    ORDER BY timestamp, date_generation DESC\n) t\nORDER BY timestamp ASC",
