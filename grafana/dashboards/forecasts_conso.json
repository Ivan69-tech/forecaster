{
  "uid": "forecasts-conso",
  "title": "Prévisions de Consommation",
  "description": "Prévisions LightGBM 48h — site-demo-01",
  "tags": ["forecaster", "consommation"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now+48h"
  },
  "timepicker": {
    "refresh_intervals": ["30s", "1m", "5m", "15m"]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Consommation prévue — 48h (kW)",
      "description": "Prévisions LightGBM générées par le ConsumptionModel. Zone grise = passé, courbe bleue = futur prévu.",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "forecaster-pg" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT timestamp AS \"time\", puissance_kw AS \"Prévision conso (kW)\" FROM forecasts_consommation WHERE site_id = 'site-demo-01' AND $__timeFilter(timestamp) ORDER BY timestamp ASC",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "showPoints": "never"
          },
          "unit": "watt",
          "displayName": "Consommation prévue",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500000 },
              { "color": "red", "value": 650000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Prochaine heure (kW)",
      "description": "Puissance prévue dans la prochaine heure",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "forecaster-pg" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT AVG(puissance_kw) AS \"kW\" FROM forecasts_consommation WHERE site_id = 'site-demo-01' AND timestamp >= NOW() AND timestamp < NOW() + INTERVAL '1 hour'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500000 },
              { "color": "red", "value": 650000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Pic prévu 48h (kW)",
      "description": "Puissance maximale prévue sur les 48 prochaines heures",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 12 },
      "datasource": { "type": "postgres", "uid": "forecaster-pg" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT MAX(puissance_kw) AS \"kW\" FROM forecasts_consommation WHERE site_id = 'site-demo-01' AND timestamp >= NOW() AND timestamp < NOW() + INTERVAL '48 hours'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500000 },
              { "color": "red", "value": 650000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Horizon couvert",
      "description": "Nombre d'heures de prévision disponibles",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
      "datasource": { "type": "postgres", "uid": "forecaster-pg" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COUNT(*) / 4 AS \"Heures\" FROM forecasts_consommation WHERE site_id = 'site-demo-01' AND timestamp >= NOW()",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Version modèle",
      "description": "Version du ConsumptionModel actif",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
      "datasource": { "type": "postgres", "uid": "forecaster-pg" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT CONCAT(version, ' (MAPE: ', ROUND(mape_validation::numeric, 1), '%)') AS \"Modèle\" FROM modeles_versions WHERE type_modele = 'consumption' AND actif = true LIMIT 1",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Prévisions détaillées — prochaines 6 heures",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "postgres", "uid": "forecaster-pg" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT timestamp AT TIME ZONE 'Europe/Paris' AS \"Heure (Paris)\", ROUND(puissance_kw::numeric, 1) AS \"Puissance (kW)\", horizon_h AS \"Horizon (h)\", TO_CHAR(date_generation AT TIME ZONE 'Europe/Paris', 'HH24:MI') AS \"Généré à\" FROM forecasts_consommation WHERE site_id = 'site-demo-01' AND timestamp >= NOW() AND timestamp < NOW() + INTERVAL '6 hours' ORDER BY timestamp ASC",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Puissance (kW)" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 450 },
                    { "color": "red", "value": 600 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Heure (Paris)", "desc": false }]
      }
    }
  ]
}
